    "required": true,
    "profile": "metadata_only_future_runtime",
    "network_mode": "none",
    "file_system": "read_only_metadata",
    "notes": "Declared only for future runtime review; no sandbox is started by this module pack."
  },
  "permissions": [
    "capability.list",
    "capability.invoke",
    "memory.retrieve",
    "context.compile",
    "trace.read"

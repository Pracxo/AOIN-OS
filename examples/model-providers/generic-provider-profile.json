  "tool_use_policy": {
    "tool_execution_allowed": false
  },
  "risk_level": "medium",
  "external_calls_allowed": false,
  "credentials_required": false,
  "metadata": {
    "provider_activation_enabled": false,
    "provider_endpoint_present": false

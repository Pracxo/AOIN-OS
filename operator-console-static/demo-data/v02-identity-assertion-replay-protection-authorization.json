  "replay_key_contract": {
    "schema_version": "identity-assertion-replay-key/v1",
    "domain_separator": "AION-IDENTITY-ASSERTION-REPLAY-V1\\0",
    "identity_input": [
      "issuer",
      "assertion_id"
    ],
    "excluded_inputs": [
      "signature",
      "key_id",
      "actor_id",
      "subject",
      "workspace_id",
      "roles",
      "permissions",
      "security_scopes",
      "metadata",
      "request_ids",
      "trace_ids",
      "correlation_ids"
    ],
    "derivation": "sha256(domain_separator + canonical_json_bytes(schema_version, issuer, assertion_id)).hexdigest()",
    "persisted_value": "derived_replay_key_only",
    "raw_issuer_persisted": false,
    "raw_assertion_id_persisted": false,
    "assertion_fingerprint_reused_as_replay_key": false
  },
  "replay_record_contract": {
    "schema_version": "identity-assertion-replay-record/v1",
    "required_fields": [
      "schema_version",
      "replay_key",
      "issuer_fingerprint",
      "assertion_fingerprint",
      "claimed_at",
      "assertion_expires_at",
      "retain_until",
      "created_at"
    ],
    "strict_pydantic_v2": true,
    "extra": "forbid",
    "frozen_evidence": true,
    "utc_datetimes": true,
    "hex_fingerprint_length": 64,
    "stores_raw_identity_claims": false,
    "stores_request_data": false,
    "stores_signature": false,
    "stores_key_material": false
  },
  "retention_policy": {
    "minimum_retention_seconds": 86400,
    "maximum_retention_seconds": 604800,
    "cleanup_batch_size": 1000,
    "minimum_retention_allowed_range": [
      300,
      604800
    ],
    "maximum_retention_allowed_range": [
      "minimum_retention_seconds",
      2592000
    ],
    "cleanup_batch_size_allowed_range": [
      1,
      10000
    ],
    "explicit_cleanup_only": true,
    "background_cleanup_scheduler_approved": false,
    "stale_record_fail_closed": true
  },
  "database_table_contract": {
    "table_name": "aion_identity_assertion_replay_claims",
    "primary_key": "replay_key",
    "indexes": [
      "retain_until",
      "claimed_at",
      "assertion_expires_at"
    ],
    "repository_constructor": "IdentityAssertionReplayRepository(*, engine: Engine, auto_create: bool = False)",
    "auto_create_default": false,
    "test_auto_create_allowed": true,
    "production_auto_create_allowed": false,
    "migration_authorized": false
  },
  "atomic_claim_contract": {
    "operation": "claim(record: IdentityAssertionReplayRecord) -> IdentityAssertionReplayRepositoryResult",
    "primary_algorithm": "single_insert_unique_constraint",
    "select_then_insert_primary_algorithm": false,
    "delete_replace_existing_record": false,
    "duplicate_same_fingerprint": "replay_detected",
    "duplicate_different_fingerprint": "identifier_collision",
    "repository_failure": "fail_closed_without_exception_text"
  },
  "service_contract": {
    "service": "IdentityAssertionReplayProtectionService",
    "operation": "protect(envelope, verification_bundle)",
    "requires_verified_bundle_before_repository_access": true,
    "bundle_envelope_mismatch_accesses_repository": false,
    "request_authenticated": false,
    "runtime_effect": false
  },
  "pipeline_contract": {
    "pipeline": "OfflineIdentityAssertionVerificationPipeline",
    "registered_in_kernel_container": false,
    "called_from_middleware": false,
    "called_from_route": false,
    "returns_cryptographic_and_replay_evidence": true
  },
  "reason_code_registry": [
    "identity_assertion_replay_claimed",
    "identity_assertion_replay_detected",
    "identity_assertion_identifier_collision",
    "identity_assertion_verification_required",
    "identity_assertion_verification_bundle_mismatch",
    "identity_assertion_replay_repository_unavailable",
    "identity_assertion_replay_schema_unavailable",
    "identity_assertion_replay_record_retained",
    "identity_assertion_replay_cleanup_completed",
    "identity_assertion_replay_cleanup_failed_closed",
    "replay_protection_performed",
    "replay_protection_failed_closed",
    "request_authentication_not_applied",
    "actor_context_not_applied",
    "request_identity_context_not_applied",
    "runtime_integration_disabled",
    "runtime_authentication_disabled",
    "authorization_scope_implementation_only",
    "runtime_no_go_status_locked"
  ],
  "threat_model_required_cases": [
    "check-then-insert race",
    "concurrent duplicate claims",
    "two repository instances using one database",
    "database rollback after unique-constraint conflict",
    "assertion-ID reuse",
    "same assertion ID with changed payload",
    "same assertion ID under different issuer",
    "replay-key derivation ambiguity",
    "replay-key domain separation",
    "fingerprint mismatch",
    "verification-bundle substitution",
    "unverified assertion reaching repository",
    "database unavailable",
    "schema unavailable",
    "cleanup and claim race",
    "clock skew",
    "retention underflow",
    "retention overflow",
    "stale record remaining after retention",
    "raw assertion persistence",
    "raw claim persistence",
    "raw identifier logging",
    "SQL exception leakage",
    "runtime in-memory store substitution",
    "request integration before formal authorization",
    "replay success misrepresented as request authentication"
  ],
  "replay_protection_required_before_request_integration": true
